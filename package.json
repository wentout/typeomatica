{
	"name": "typeomatica",
	"version": "0.3.59",
	"description": "type logic against javascript metaprogramming",
	"engines": {
		"node": ">=16"
	},
	"main": "lib/index.js",
	"module": "lib/esm/esm.js",
	"types": "lib/index.d.ts",
	"sideEffects": false,
	"exports": {
		".": {
			"import": {
				"types": "./lib/esm/esm.d.ts",
				"default": "./lib/esm/esm.js"
			},
			"require": {
				"types": "./lib/index.d.ts",
				"default": "./lib/index.js"
			}
		},
		"./module": {
			"import": "./lib/esm/esm.js",
			"require": "./lib/index.js",
			"default": "./lib/index.js"
		}
	},
	"files": [
		"README.md",
		"FOR_HUMANS.md",
		"AGENTS.md",
		"EXAMPLES.md",
		"LICENSE",
		"lib",
		"examples"
	],
	"directories": {
		"build": "lib/"
	},
	"scripts": {
		"build": "rm -rf ./lib && npx tsc --target esnext --pretty && npx tsc --project tsconfig.esm.json && printf '{\"type\":\"module\"}\\n' > lib/esm/package.json",
		"lint:lib": "npx eslint --fix ./lib",
		"lint:src": "npx eslint --fix ./src",
		"test": "npx jest",
		"test:cov": "npx jest --collectCoverage",
		"test:esm": "npx vitest run test/esm",
		"test:addition": "node --test --experimental-test-coverage  ./test/noJest.ts",
		"examples": "node examples/01-function-constructor-getter.js && node examples/02-buffer-toJSON.js && node examples/03-shared-array-buffer.js && printf 'hello\\n' | node examples/05-stdin-stdout.js && node examples/04-uint-fields.js && node examples/06-shared-field-prototype-chain.js && node examples/07-shared-field-different-objects.js && node examples/08-async-field.js && node examples/09-pub-sub-field.js && node examples/10-iterator-field.js && node examples/11-time-to-live-field.js && node examples/12-loop-field.js && node examples/13-recursive-field.js && node examples/14-async-loop-field.js && node examples/15-async-recursive-field.js",
		"debug:on-issues": "echo 'if debugger; command is not working try other Node.JS version'",
		"debug": "node --inspect-brk --nolazy node_modules/.bin/jest --runInBand --detectOpenHandles",
		"debug:jest": "node --nolazy --inspect-brk ./node_modules/jest/bin/jest.js --runInBand --colors --verbose",
		"debug:usual": "npx --node-options=--inspect-brk jest --runInBand --colors --verbose",
		"prepare": "husky install"
	},
	"keywords": [
		"strict",
		"types",
		"runtime",
		"javascript",
		"typescript",
		"metaprogramming",
		"proxy",
		"decorator",
		"validation"
	],
	"author": "went.out@gmail.com",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wentout/typeomatica.git"
	},
	"homepage": "https://github.com/wentout/typeomatica#readme",
	"bugs": {
		"url": "https://github.com/wentout/typeomatica/issues"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^9.39.2",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.9.4",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"eslint": "^9.39.4",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"jest": "^30.4.2",
		"json5": "^2.2.3",
		"lint-staged": "^16.4.0",
		"set-value": "^4.1.0",
		"ts-jest": "^29.4.11",
		"typescript": "^5.9.3",
		"vitest": "^4.1.9"
	}
}
